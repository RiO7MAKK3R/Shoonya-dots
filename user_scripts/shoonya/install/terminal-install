#!/usr/bin/env bash
set -euo pipefail

# Shoonya OS · Install Terminal

TERMINALS=$(
  cat <<'EOF'
kitty|Kitty|Fast, GPU-accelerated terminal (recommended)
alacritty|Alacritty|GPU-accelerated, minimal terminal
ghostty|Ghostty|Modern terminal with native Wayland support
EOF
)

fzf_args=(
  --delimiter='|'
  --with-nth=2
  --preview 'echo {3}'
  --preview-label='Description'
  --preview-window 'down:50%:wrap'
  --color 'pointer:green,marker:green'
  --prompt 'Install Terminal > '
)

selection=$(echo "$TERMINALS" | fzf "${fzf_args[@]}")

[[ -z "$selection" ]] && exit 0

IFS='|' read -r package _ _ <<<"$selection"

case "$package" in
  kitty)     desktop_id="kitty.desktop" ;;
  alacritty) desktop_id="Alacritty.desktop" ;;
  ghostty)   desktop_id="com.mitchellh.ghostty.desktop" ;;
  *)
    echo "Unknown terminal"
    exit 1
    ;;
esac

echo
echo "▶ Installing $package..."
echo

if omarchy-pkg-add "$package"; then
  if [[ "$package" == "alacritty" ]]; then
    mkdir -p ~/.local/share/applications
    cat > ~/.local/share/applications/Alacritty.desktop << EOF
[Desktop Entry]
Type=Application
TryExec=alacritty
Exec=alacritty
Icon=Alacritty
Terminal=false
Categories=System;TerminalEmulator;
Name=Alacritty
GenericName=Terminal
StartupWMClass=Alacritty
X-TerminalArgExec=-e
X-TerminalArgAppId=--class=
X-TerminalArgTitle=--title=
X-TerminalArgDir=--working-directory=
EOF
  fi

  mkdir -p ~/.config
  echo "$desktop_id" > ~/.config/xdg-terminals.list
fi

echo
echo "✔ Terminal installed and set as default."
echo
echo "Press Enter or Esc to close."

while read -rsn1 key; do
  [[ $key == "" || $key == $'\e' ]] && break
done
