#!/usr/bin/env bash
set -euo pipefail

# Shoonya OS · Dev Environment Remover
# fzf-based multi-select TUI

# ---------- AUR helper ----------

if command -v paru &>/dev/null; then
  AUR=paru
elif command -v yay &>/dev/null; then
  AUR=yay
else
  echo "❌ No AUR helper found. Please install paru or yay."
  exit 1
fi

pkg_remove() {
  "$AUR" -Rns --noconfirm "$@" 2>/dev/null || true
}

# ---------- helpers ----------

ensure_mise() {
  if command -v mise >/dev/null 2>&1; then
    return 0
  fi
  echo "mise not found. Nothing to remove."
  exit 0
}

mise_remove() {
  local tool="$1"
  ensure_mise
  mise uninstall "$tool" --all 2>/dev/null || true
  mise rm -g "$tool" 2>/dev/null || true
}

remove_php() {
  pkg_remove php composer php-sqlite xdebug
}

# ---------- dev env catalog ----------

# Format: key|Title|Description
DEV_ENVS=$(cat <<'EOF'
python|Python|Python via mise + uv
node|Node.js|Node.js runtime via mise
bun|Bun|Bun runtime via mise
deno|Deno|Deno runtime via mise
go|Go|Go toolchain via mise
ruby|Ruby|Ruby + Rails gems via mise
php|PHP|PHP + Composer + Xdebug via paru/yay
laravel|Laravel|Laravel global installer (composer)
symfony|Symfony|Symfony CLI via paru/yay
elixir|Elixir|Elixir + Erlang via mise
phoenix|Phoenix|Phoenix framework (shares Elixir/Erlang)
rust|Rust|Rust toolchain via rustup
java|Java|Java SDK via mise
zig|Zig|Zig compiler + ZLS via mise
ocaml|OCaml|OCaml + opam toolchain
dotnet|.NET|.NET SDK via mise
clojure|Clojure|Clojure via mise + rlwrap
scala|Scala|Scala + scala-cli via mise
EOF
)

# ---------- fzf TUI ----------

fzf_args=(
  --multi
  --delimiter='|'
  --with-nth=2
  --preview 'echo {3}'
  --preview-label='Description'
  --preview-window 'down:60%:wrap'
  --bind 'alt-p:toggle-preview'
  --bind 'alt-j:preview-down,alt-k:preview-up'
  --bind 'alt-d:preview-half-page-down,alt-u:preview-half-page-up'
  --color 'pointer:red,marker:red'
  --prompt 'Remove Dev Environments > '
  --header 'TAB: multi-select  ENTER: remove  ESC: cancel'
)

selection=$(echo "$DEV_ENVS" | fzf "${fzf_args[@]}") || true

[[ -z "$selection" ]] && echo "No selection made. Exiting." && exit 0

# ---------- removal loop ----------

echo "$selection" | while IFS='|' read -r key title _; do
  echo
  echo "▶ Removing: $title"
  echo

  case "$key" in
    python)
      mise_remove python
      rm -f ~/.local/bin/uv ~/.local/bin/uvx 2>/dev/null || true
      ;;
    node)
      mise_remove node
      ;;
    bun)
      mise_remove bun
      ;;
    deno)
      mise_remove deno
      ;;
    go)
      mise_remove go
      ;;
    ruby)
      mise_remove ruby
      rm -f ~/.gemrc
      ;;
    php)
      remove_php
      ;;
    laravel)
      composer global remove laravel/installer 2>/dev/null || true
      ;;
    symfony)
      pkg_remove symfony-cli
      ;;
    elixir)
      mise_remove elixir
      mise_remove erlang
      ;;
    phoenix)
      # Phoenix shares Elixir/Erlang — only remove mix archives
      ensure_mise
      mise x elixir -- mix archive.uninstall phx_new 2>/dev/null || true
      ;;
    rust)
      rustup self uninstall -y 2>/dev/null || true
      ;;
    java)
      mise_remove java
      ;;
    zig)
      mise_remove zig
      mise_remove zls
      ;;
    ocaml)
      opam switch remove default -y 2>/dev/null || true
      rm -rf ~/.opam 2>/dev/null || true
      sudo rm -f /usr/local/bin/opam 2>/dev/null || true
      ;;
    dotnet)
      mise_remove dotnet
      ;;
    clojure)
      mise_remove clojure
      pkg_remove rlwrap
      ;;
    scala)
      mise_remove scala
      mise_remove scala-cli
      # Java may be shared — leave it unless explicitly selected
      ;;
  esac

  echo "✔ $title removed."
done

# ---------- done ----------

echo ""
echo "✔ All selected environments removed."
echo ""
echo "Press Enter or Esc to close."
while true; do
  read -rsn1 key
  [[ $key == "" || $key == $'\e' ]] && break
done
